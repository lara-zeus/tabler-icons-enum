{
    "name": "lara-zeus/tabler-icons-enum",
    "description": "Lara-zeus tabler icons enum",
    "keywords": [
        "laravel",
        "lara-zeus",
        "tabler",
        "icons",
        "enum",
        "filamentphp"
    ],
    "homepage": "https://larazeus.com/tabler-icons-enum",
    "support": {
        "issues": "https://github.com/lara-zeus/tabler-icons-enum/issues",
        "source": "https://github.com/lara-zeus/tabler-icons-enum"
    },
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Lara Zeus",
            "email": "info@larazeus.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/support": "*",
        "secondnetwork/blade-tabler-icons": "^3.30",
        "spatie/laravel-package-tools": "^1.19"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/larastan": "^2.0.1",
        "orchestra/testbench": "^8.0",
        "phpstan/extension-installer": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "LaraZeus\\Tabler\\": "src"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraZeus\\Tabler\\TablerServiceProvider"
            ]
        }
    },
    "prefer-stable": true
}
